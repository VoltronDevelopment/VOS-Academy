ACADEMY_SESSION_SECRET=replace-with-long-random-secret
ACADEMY_ADMIN_EMAIL=admin@voltroncoat.com
ACADEMY_ADMIN_PASSWORD=replace-admin-password
ACADEMY_EMPLOYEE_PASSWORD=replace-employee-password
CAMS_AUTH_TOKEN=replace-cams-token

# Local default backend uses SQLite. Production should use DynamoDB + S3.
ACADEMY_STORAGE_DRIVER=sqlite

# AWS production backend
VOLTRON_AWS_REGION=ap-south-1
ACADEMY_TABLE_NAME=VoltronAcademy
ACADEMY_UPLOAD_BUCKET=voltron-academy-uploads
ACADEMY_UPLOAD_PREFIX=training/
